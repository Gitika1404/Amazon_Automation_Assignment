<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml — Parallel Execution Configuration

    parallel="methods" : each @Test method runs in its own thread
    thread-count="2"   : 2 threads run simultaneously (one per test case)

    This ensures TC1 (iPhone) and TC2 (Galaxy) execute at the same time.
    ThreadLocal in BaseTest gives each thread its own WebDriver instance.
-->
<suite name="Amazon Parallel Test Suite" parallel="methods" thread-count="2" verbose="2">

    <test name="Amazon Device Search Tests">
        <classes>
            <class name="com.amazon.tests.AmazonSearchTest">
                <methods>
                    <include name="testIPhoneSearch"/>
                    <include name="testGalaxySearch"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>